{"name":"vs_code","settings":"{\"settings\":\"{\\r\\n    \\\"workbench.startupEditor\\\": \\\"none\\\",\\r\\n    \\\"C_Cpp.clang_format_fallbackStyle\\\": \\\"Google\\\",\\r\\n    \\\"C_Cpp.clang_format_style\\\": \\\"Google\\\",\\r\\n    \\\"C_Cpp.formatting\\\": \\\"vcFormat\\\",\\r\\n    \\\"[cpp]\\\": {\\r\\n        \\\"editor.defaultFormatter\\\": \\\"ms-vscode.cpptools\\\"\\r\\n    },\\r\\n    \\\"C_Cpp.clang_format_sortIncludes\\\": false,\\r\\n    \\\"editor.formatOnPaste\\\": true,\\r\\n    \\\"editor.formatOnSave\\\": true,\\r\\n    \\\"editor.wordWrapColumn\\\": 150,\\r\\n    \\\"diffEditor.ignoreTrimWhitespace\\\": false,\\r\\n    \\\"editor.minimap.autohide\\\": \\\"mouseover\\\",\\r\\n    \\\"[markdown]\\\": {\\r\\n        \\\"editor.wordWrap\\\": \\\"off\\\"\\r\\n    },\\r\\n    \\\"diffEditor.wordWrap\\\": \\\"on\\\",\\r\\n    \\\"explorer.confirmDelete\\\": false,\\r\\n    \\\"security.workspace.trust.untrustedFiles\\\": \\\"open\\\",\\r\\n    \\\"C_Cpp.vcFormat.indent.braces\\\": true,\\r\\n    \\\"C_Cpp.vcFormat.newLine.beforeCatch\\\": false,\\r\\n    \\\"C_Cpp.vcFormat.newLine.beforeElse\\\": false,\\r\\n    \\\"C_Cpp.vcFormat.newLine.beforeOpenBrace.block\\\": \\\"sameLine\\\",\\r\\n    \\\"C_Cpp.vcFormat.newLine.beforeOpenBrace.function\\\": \\\"sameLine\\\",\\r\\n    \\\"C_Cpp.vcFormat.newLine.beforeOpenBrace.lambda\\\": \\\"sameLine\\\",\\r\\n    \\\"C_Cpp.vcFormat.newLine.beforeOpenBrace.namespace\\\": \\\"sameLine\\\",\\r\\n    \\\"C_Cpp.vcFormat.newLine.beforeOpenBrace.type\\\": \\\"sameLine\\\",\\r\\n    \\\"explorer.confirmDragAndDrop\\\": false,\\r\\n    \\\"workbench.colorCustomizations\\\": {\\r\\n        \\\"statusBar.background\\\": \\\"#363738\\\",\\r\\n        \\\"statusBar.noFolderBackground\\\": \\\"#212121\\\",\\r\\n        \\\"statusBar.debuggingBackground\\\": \\\"#263238\\\"\\r\\n        // \\\"editor.foreground.\\\": \\\"#ff0000\\\"\\r\\n    },\\r\\n    \\\"workbench.colorTheme\\\": \\\"Dark+\\\",\\r\\n    \\\"editor.minimap.showSlider\\\": \\\"always\\\",\\r\\n    \\\"editor.minimap.enabled\\\": false,\\r\\n    \\\"editor.mouseWheelZoom\\\": true,\\r\\n    \\\"window.customTitleBarVisibility\\\": \\\"auto\\\",\\r\\n    \\\"github.gitAuthentication\\\": false,\\r\\n    \\\"git.ignoreMissingGitWarning\\\": true,\\r\\n    \\\"git.enableSmartCommit\\\": true,\\r\\n    \\\"git.confirmSync\\\": false,\\r\\n    \\\"github.copilot.selectedCompletionModel\\\": \\\"\\\",\\r\\n    \\\"editor.inlineSuggest.syntaxHighlightingEnabled\\\": false,\\r\\n    \\\"github.copilot.nextEditSuggestions.enabled\\\": false,\\r\\n    \\\"github.copilot.nextEditSuggestions.fixes\\\": true,\\r\\n    \\\"github.copilot.chat.agent.thinkingTool\\\": true,\\r\\n    \\\"git.openRepositoryInParentFolders\\\": \\\"never\\\",\\r\\n    \\\"window.confirmSaveUntitledWorkspace\\\": false,\\r\\n    \\\"github.copilot.enable\\\": {\\r\\n        \\\"*\\\": false,\\r\\n        \\\"plaintext\\\": false,\\r\\n        \\\"markdown\\\": false,\\r\\n        \\\"scminput\\\": false,\\r\\n        \\\"cpp\\\": false,\\r\\n        \\\"c\\\": false\\r\\n    },\\r\\n    \\\"terminal.integrated.suggest.windowsExecutableExtensions\\\": {},\\r\\n    \\\"workbench.secondarySideBar.defaultVisibility\\\": \\\"visible\\\",\\r\\n    \\\"editor.hover.delay\\\": 1000,\\r\\n    \\\"editor.hover.above\\\": false,\\r\\n    \\\"txtsyntax.associations\\\": [\\r\\n        \\\".ini\\\",\\r\\n        \\\".cf\\\",\\r\\n        \\\".cnf\\\",\\r\\n        \\\".conf\\\",\\r\\n        \\\".cfg\\\",\\r\\n        \\\".unx\\\",\\r\\n        \\\".eds\\\",\\r\\n        \\\".log\\\",\\r\\n        \\\".out\\\",\\r\\n        \\\".err\\\",\\r\\n        \\\".inf\\\",\\r\\n        \\\".info\\\",\\r\\n        \\\".tmp\\\",\\r\\n        \\\".temp\\\",\\r\\n        \\\".file\\\",\\r\\n        \\\".repo\\\",\\r\\n        \\\".plain\\\",\\r\\n        \\\".desktop\\\",\\r\\n        \\\".properties\\\",\\r\\n        \\\".txt\\\"\\r\\n    ],\\r\\n    \\\"http.systemCertificates